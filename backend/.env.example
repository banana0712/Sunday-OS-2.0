# SundayOS 环境变量配置模板
# 复制此文件为 .env 并填入你的配置
# cp .env.example .env

# ========== 应用配置 ==========
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ========== API 安全 ==========
# 生产环境务必修改！用于快捷指令调用时的鉴权
SUNDAY_API_KEY=sunday-os-dev-key-change-in-production

# ========== LLM 配置（四选一）==========

# 🆓 方案一：蚂蚁百灵（推荐，50万token/天免费）
# 注册：https://chat.ant-ling.com/open → 注册登录 → 创建令牌
LLM_PROVIDER=ling_studio
LLM_API_KEY=ant_your_key_here
LLM_MODEL=Ling-2.6-1T

# 🆓 方案二：阿里通义千问（2000次/天免费）
# 注册：https://modelscope.cn → 个人中心 → 访问令牌 → 创建令牌
# LLM_PROVIDER=dashscope
# LLM_API_KEY=sk_your_key_here
# LLM_MODEL=qwen-plus

# 💰 方案三：OpenAI 官方（付费）
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-your-openai-key
# LLM_MODEL=gpt-4o-mini

# 🔧 方案四：自定义 OpenAI 兼容 API
# LLM_PROVIDER=custom
# LLM_API_KEY=your-key
# LLM_BASE_URL=https://your-api.com/v1
# LLM_MODEL=your-model-name

LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# ========== 记忆系统配置 ==========
# 开发环境使用内存存储即可
# 生产环境可配置 ChromaDB:
# CHROMADB_HOST=localhost
# CHROMADB_PORT=8000

# ========== 数据库（生产环境）==========
# DATABASE_URL=postgresql+asyncpg://sunday:sunday@localhost:5432/sundayos
# REDIS_URL=redis://localhost:6379/0

# ========== 语音服务（可选）==========
# TTS_PROVIDER=edge          # edge (免费) / elevenlabs (高质量付费)
# ELEVENLABS_API_KEY=
# WHISPER_API_KEY=

# ========== 技能配置（可选）==========
# WEATHER_API_KEY=           # https://openweathermap.org
# SEARCH_API_KEY=

# ========== SundayOS 人格 ==========
ASSISTANT_NAME=Sunday
ASSISTANT_PERSONALITY=你是一个温暖、专业、偶尔幽默的AI助手。你的名字是Sunday。你像朋友一样与用户交流，简洁直接但充满关怀。你会记住用户的偏好和习惯，主动提供帮助。你的核心价值是效率优先、主动关怀、尊重隐私。
